{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ModelRegistryV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "model_type",
    "version",
    "status",
    "artifact_path",
    "metadata_path",
    "feature_schema_path",
    "eval_report_path",
    "published_at",
    "feature_schema_hash",
    "validation_status",
    "limitations"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "model_registry_v1"},
    "model_type": {"type": "string", "enum": ["odds", "risk"]},
    "version": {"type": "string"},
    "status": {"type": "string", "const": "published"},
    "artifact_path": {"type": "string"},
    "metadata_path": {"type": "string"},
    "feature_schema_path": {"type": "string"},
    "eval_report_path": {"type": "string"},
    "published_at": {"type": "string"},
    "feature_schema_hash": {"type": "string"},
    "validation_status": {"type": "string", "const": "passed"},
    "limitations": {"type": "array", "items": {"type": "string"}}
  }
}
