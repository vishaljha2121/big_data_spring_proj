{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ScoredPointEventV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scorer_version",
    "replay_session_id",
    "synthetic_match_id",
    "source_match_id",
    "event_id",
    "synthetic_event_id",
    "event_index",
    "replay_order",
    "event_ts",
    "player_a",
    "player_b",
    "server_player",
    "receiver_player",
    "point_winner_player",
    "point_probability_player_a",
    "point_probability_player_b",
    "selected_model_type",
    "odds_model_version",
    "feature_schema_hash",
    "risk_score",
    "risk_bucket",
    "primary_risk_signal",
    "risk_explanation",
    "missing_feature_warnings",
    "scoring_latency_ms",
    "scored_at",
    "input_event_valid",
    "feature_row_valid"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "scored_event_v1"},
    "scorer_version": {"type": "string"},
    "replay_session_id": {"type": "string"},
    "synthetic_match_id": {"type": "string"},
    "source_match_id": {"type": "string"},
    "event_id": {"type": "string"},
    "synthetic_event_id": {"type": "string"},
    "event_index": {"type": "integer"},
    "replay_order": {"type": "integer"},
    "event_ts": {"type": ["string", "null"]},
    "player_a": {"type": "string"},
    "player_b": {"type": "string"},
    "server_player": {"type": ["string", "null"]},
    "receiver_player": {"type": ["string", "null"]},
    "point_winner_player": {"type": ["string", "null"]},
    "point_probability_player_a": {"type": "number", "minimum": 0, "maximum": 1},
    "point_probability_player_b": {"type": "number", "minimum": 0, "maximum": 1},
    "selected_model_type": {"type": "string"},
    "odds_model_version": {"type": "string"},
    "feature_schema_hash": {"type": "string"},
    "risk_score": {"type": "number", "minimum": 0, "maximum": 1},
    "risk_bucket": {"type": "string", "enum": ["low", "medium", "high"]},
    "primary_risk_signal": {"type": "string"},
    "risk_explanation": {"type": "string"},
    "missing_feature_warnings": {"type": "array", "items": {"type": "string"}},
    "scoring_latency_ms": {"type": "number", "minimum": 0},
    "scored_at": {"type": "string"},
    "input_event_valid": {"type": "boolean"},
    "feature_row_valid": {"type": "boolean"}
  }
}
