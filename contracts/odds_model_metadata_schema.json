{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OddsModelMetadataV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "model_type",
    "version",
    "trained_at",
    "training_script",
    "target_column",
    "feature_columns",
    "excluded_columns",
    "feature_schema_hash",
    "input_dataset",
    "train_row_count",
    "validation_row_count",
    "test_row_count",
    "validation_auc",
    "test_auc",
    "validation_brier_score",
    "test_brier_score",
    "random_seed",
    "limitations"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "odds_model_metadata_v1"},
    "model_type": {"type": "string", "const": "odds"},
    "version": {"type": "string"},
    "trained_at": {"type": "string"},
    "training_script": {"type": "string"},
    "target_column": {"type": "string"},
    "feature_columns": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "excluded_columns": {"type": "array", "items": {"type": "string"}},
    "feature_schema_hash": {"type": "string"},
    "input_dataset": {"type": "string"},
    "train_row_count": {"type": "integer", "minimum": 1},
    "validation_row_count": {"type": "integer", "minimum": 1},
    "test_row_count": {"type": "integer", "minimum": 1},
    "validation_auc": {"type": "number"},
    "test_auc": {"type": "number"},
    "validation_brier_score": {"type": "number"},
    "test_brier_score": {"type": "number"},
    "random_seed": {"type": "integer"},
    "limitations": {"type": "array", "items": {"type": "string"}}
  }
}
