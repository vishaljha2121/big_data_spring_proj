{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KafkaTopicConfigV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "topic",
    "partitions",
    "replication_factor",
    "retention_ms",
    "cleanup_policy",
    "max_message_bytes",
    "partition_key",
    "consumer_group"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "kafka_topic_config_v1"},
    "topic": {"type": "string"},
    "partitions": {"type": "integer", "minimum": 1},
    "replication_factor": {"type": "integer", "minimum": 1},
    "retention_ms": {"type": "integer", "minimum": 1},
    "cleanup_policy": {"type": "string", "enum": ["delete", "compact"]},
    "max_message_bytes": {"type": "integer", "minimum": 1},
    "partition_key": {"type": "string"},
    "consumer_group": {"type": "string"}
  }
}
