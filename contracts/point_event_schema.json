{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KafkaPointReplayEvent",
  "description": "Frozen raw point replay event contract for the future Kafka producer. This event intentionally excludes model features.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "replay_session_id",
    "synthetic_match_id",
    "source_match_id",
    "event_id",
    "synthetic_event_id",
    "event_index",
    "replay_order",
    "replay_offset_seconds",
    "event_ts",
    "player_a",
    "player_b",
    "server_player",
    "receiver_player",
    "point_winner_player",
    "set_number",
    "game_number",
    "point_number",
    "p1_score",
    "p2_score",
    "is_ace",
    "is_double_fault",
    "is_break_point",
    "source_file"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "point_event_v1"},
    "replay_session_id": {"type": "string"},
    "synthetic_match_id": {"type": "string"},
    "source_match_id": {"type": "string"},
    "event_id": {"type": "string"},
    "synthetic_event_id": {"type": "string"},
    "event_index": {"type": "integer", "minimum": 0},
    "replay_order": {"type": "integer", "minimum": 0},
    "replay_offset_seconds": {"type": "number", "minimum": 0},
    "event_ts": {"type": ["string", "null"], "description": "ISO timestamp generated by the replay manifest or null when unavailable."},
    "player_a": {"type": "string"},
    "player_b": {"type": "string"},
    "server_player": {"type": ["string", "null"]},
    "receiver_player": {"type": ["string", "null"]},
    "point_winner_player": {"type": ["string", "null"]},
    "set_number": {"type": ["integer", "null"]},
    "game_number": {"type": ["integer", "null"]},
    "point_number": {"type": ["integer", "null"]},
    "p1_score": {"type": ["string", "null"]},
    "p2_score": {"type": ["string", "null"]},
    "is_ace": {"type": ["boolean", "null"]},
    "is_double_fault": {"type": ["boolean", "null"]},
    "is_break_point": {"type": ["boolean", "null"]},
    "source_file": {"type": ["string", "null"]}
  }
}
